{
  "name": "product-scraper",
  "version": "1.0.0",
  "description": "Scrape product data from hoathanhphat.com.vn",
  "main": "scrape-products.js",
  "scripts": {
    "start": "node scrape-products.js",
    "generate:products": "node generate-product-pages.js",
    "scan:missing-parts": "node scan-missing-parts.js",
    "audit:product-dedup": "node audit-product-dedup.js",
    "build:canonical-products": "node build-canonical-products.js",
    "scrape:new-products": "node scrape-new-product-sources.js",
    "scrape:viglaceratiles": "node scrape-new-product-sources.js --source=viglaceratiles",
    "scrape:eurotile": "node scrape-new-product-sources.js --source=eurotile",
    "scrape:vastastone": "node scrape-new-product-sources.js --source=vastastone"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12"
  }
}
